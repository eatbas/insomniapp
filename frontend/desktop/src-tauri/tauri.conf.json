{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "insomniAPP",
  "version": "0.4.1",
  "identifier": "com.insomniapp.app",
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDE0M0ZDOEE2QzI1MzcxN0MKUldSOGNWUENwc2cvRkNQZHovcGt0d0tEUHBTSnp3dHRJSEhDamtxbFRROXFjMnBpYmtlaUhRZmYK",
      "endpoints": [
        "https://github.com/eatbas/insomniapp/releases/latest/download/latest.json"
      ]
    }
  },
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "insomniAPP",
        "width": 240,
        "height": 78,
        "resizable": false,
        "visible": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "startMenuFolder": "insomniAPP"
      }
    }
  }
}
